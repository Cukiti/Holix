@model Holix.Models.HomeViewModel

@{
    ViewData["Title"] = "Digital Agency";
}

<!-- Hero Section -->
<section id="home" class="d-flex align-items-center sweep-section" style="min-height: 100vh; padding-top: 100px; background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); position: relative; overflow: hidden;">
    <canvas id="heroSweepCanvas" class="section-sweep-canvas"></canvas>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 position-relative">
                <span class="text-primary fw-bold mb-3 d-block hero-float-label" id="heroSubtitle"><i class="fa-solid fa-minus me-2"></i>Welcome to Our Agency</span>
                <h1 class="hero-heading mb-4 hero-float-title" id="heroTitle">Smart Ideas for your<br>Brand are Here</h1>
                <p class="lead text-secondary mb-5 pe-lg-5 hero-float-desc" id="heroDesc">
                    Transformamos tu visión en experiencias digitales excepcionales. En Holix, combinamos diseño UX/UI de vanguardia, desarrollo robusto y marketing estratégico para impulsar el éxito de tu negocio en el mundo digital.
                </p>
                <div class="d-flex align-items-center flex-wrap">
                    <a href="#services" class="btn btn-primary me-4 mb-2 hero-btn-pulse">DISCOVER MORE</a>
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none fw-bold mb-2">
                        <span class="btn-play me-3"><i class="fa-solid fa-play ms-1"></i></span>
                        How it works
                    </a>
                </div>
                <div class="hero-shape" style="width:12px;height:12px;border-radius:50%;background:#22c55e;top:15%;left:5%;"></div>
                <div class="hero-shape" style="width:8px;height:8px;border-radius:50%;background:#22c55e;top:50%;left:2%;"></div>
                <div class="hero-shape" style="width:10px;height:10px;border-radius:50%;background:#22c55e;top:25%;right:10%;"></div>
                <div class="hero-shape" style="width:6px;height:6px;border-radius:50%;background:#22c55e;top:65%;right:5%;"></div>
                <div class="hero-shape" style="width:14px;height:2px;border-radius:2px;background:#22c55e;top:35%;left:10%;transform:rotate(45deg);"></div>
                <div class="hero-shape" style="width:10px;height:2px;border-radius:2px;background:#22c55e;top:75%;right:15%;transform:rotate(-30deg);"></div>
            </div>
            <div class="col-lg-6 position-relative">
                <div class="hero-circle mx-auto hero-circle-pulse"></div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
