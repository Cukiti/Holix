        (function() {
            var wrap = document.querySelector('.trophy-icon-wrap');
            if (!wrap) return;
            wrap.addEventListener('click', function(e) {
                wrap.classList.remove('trophy-bounce');
                void wrap.offsetWidth;
                wrap.classList.add('trophy-bounce');
                var sparkleCount = 8;
                var rect = wrap.getBoundingClientRect();
                var cx = rect.left + rect.width / 2;
                var cy = rect.top + rect.height / 2;
                for (var i = 0; i < sparkleCount; i++) {
                    var dot = document.createElement('div');
                    dot.className = 'trophy-sparkle';
                    var angle = (i / sparkleCount) * Math.PI * 2;
                    var dist = 40 + Math.random() * 30;
                    var dx = Math.cos(angle) * dist;
                    var dy = Math.sin(angle) * dist;
                    dot.style.setProperty('--dx', dx + 'px');
                    dot.style.setProperty('--dy', dy + 'px');
                    dot.style.left = cx + 'px';
                    dot.style.top = cy + 'px';
                    document.body.appendChild(dot);
                    dot.addEventListener('animationend', function() { this.remove(); });
                }
            });
        })();
