    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 pe-lg-5">
                <div class="row g-3">
                    <div class="col-6 mt-4">
                        <div class="about-image" style="height: 300px;">
                            <img src="https://images.unsplash.com/photo-1515162816999-a0c47dc192f7?auto=format&fit=crop&w=600&q=80" alt="Team">
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="about-image" style="height: 300px;">
                            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&w=600&q=80" alt="Meeting">
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 ps-lg-5">
                <h2 class="fw-bold fs-1 mb-4">We create some things, Design for your success future.</h2>
                <p class="text-secondary mb-4">
                    Lorem Ipsum is simply dummy text of free available in market the way printing and typesetting industry has been the industry's standard dummy text ever.
                </p>
                <ul class="list-unstyled mb-5">
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fa-solid fa-circle text-primary me-3 fs-6" style="font-size: 0.6rem !important;"></i>
                        <span class="text-secondary fw-medium">Price of additional materials or parts (if needed)</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fa-solid fa-circle text-primary me-3 fs-6" style="font-size: 0.6rem !important;"></i>
                        <span class="text-secondary fw-medium">Transportation cost for carrying new materials/parts</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fa-solid fa-circle text-primary me-3 fs-6" style="font-size: 0.6rem !important;"></i>
                        <span class="text-secondary fw-medium">You will get 100% money back offer.</span>
                    </li>
                </ul>
                <div class="d-flex align-items-center flex-wrap">
                    <a href="#about" class="btn btn-primary px-4 py-2 me-4 mb-2">KNOW MORE</a>
                    <div class="d-flex align-items-center mb-2">
                        <div class="text-primary fs-2 me-2"><i class="fa-solid fa-trophy"></i></div>
                        <span class="fw-bold text-primary fs-5">10+ Years Experience</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5" style="background-color: #fafafa;">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block">-What We Offer-</span>
            <h2 class="fw-bold fs-1 mb-3">Our Creative Services</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;">
                Get the most of reduction in your team's operating costs for the whole product which creates amazing UI/UX experiences.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @if(Model != null && Model.Services != null && Model.Services.Any()) {
                foreach (var service in Model.Services.Take(4))
                {
                    <div class="col-md-6 col-lg-5">
                        <div class="service-card p-4 h-100 d-flex flex-row align-items-start">
                            <div class="service-icon-container me-4 flex-shrink-0">
                                <i class="@service.Icon"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-3">@service.Title</h5>
                                <p class="text-secondary small mb-4">@service.Description</p>
                                <a href="#" class="text-dark fw-bold text-decoration-none small">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                            </div>
                        </div>
                    </div>
                }
            } else {
                <div class="col-md-6 col-lg-5">
                    <div class="service-card p-4 h-100 d-flex flex-row align-items-start">
                        <div class="service-icon-container me-4 flex-shrink-0"><i class="fa-solid fa-pen-nib"></i></div>
                        <div>
                            <h5 class="fw-bold mb-3">UI/UX Creative Design</h5>
                            <p class="text-secondary small mb-4">Lorem ipsum dolor sit amet, consectetur adipiscing semper turpis. Nullam eget luctte gula and adipiscing elit.</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none small">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-5">
                    <div class="service-card p-4 h-100 d-flex flex-row align-items-start">
                        <div class="service-icon-container me-4 flex-shrink-0"><i class="fa-solid fa-code"></i></div>
                        <div>
                            <h5 class="fw-bold mb-3">App Development</h5>
                            <p class="text-secondary small mb-4">Lorem ipsum dolor sit amet, consectetur adipiscing semper turpis. Nullam eget luctte gula and adipiscing elit.</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none small">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-5">
                    <div class="service-card p-4 h-100 d-flex flex-row align-items-start">
                        <div class="service-icon-container me-4 flex-shrink-0"><i class="fa-solid fa-keyboard"></i></div>
                        <div>
                            <h5 class="fw-bold mb-3">Professional Content Writer</h5>
                            <p class="text-secondary small mb-4">Lorem ipsum dolor sit amet, consectetur adipiscing semper turpis. Nullam eget luctte gula and adipiscing elit.</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none small">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-5">
                    <div class="service-card p-4 h-100 d-flex flex-row align-items-start">
                        <div class="service-icon-container me-4 flex-shrink-0"><i class="fa-solid fa-bezier-curve"></i></div>
                        <div>
                            <h5 class="fw-bold mb-3">Graphic Design</h5>
                            <p class="text-secondary small mb-4">Lorem ipsum dolor sit amet, consectetur adipiscing semper turpis. Nullam eget luctte gula and adipiscing elit.</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none small">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a href="#" class="btn btn-primary px-4 py-2">GET STARTED</a>
        </div>
    </div>
</section>

<!-- Features Section (Why Choose Us) -->
<section id="features" class="py-5 my-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block">-Why Choose Us-</span>
            <h2 class="fw-bold fs-1 mb-3">Reasons to Choose Us</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;">
                Get the most of reduction in your team's operating costs for the whole product which creates amazing UI/UX experiences.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @{
                var features = new[] {
                    new { Num = "01", Title = "Free Icon Plugin" },
                    new { Num = "02", Title = "Free 6 Month Support" },
                    new { Num = "03", Title = "Customer Strategy" },
                    new { Num = "04", Title = "Best Premium Image" },
                    new { Num = "05", Title = "Most Advanced Features" },
                    new { Num = "06", Title = "Very Reasonable Price" }
                };
            }
            @foreach(var item in features)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="reason-card h-100">
                        <div class="reason-number">@item.Num</div>
                        <h5 class="fw-bold mb-3">@item.Title</h5>
                        <p class="text-secondary small mb-0">Nullam ullamcorper condimentum urna eu accumsan.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="py-5 mb-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-4">
                <h2 class="fw-bold fs-1 mb-4 pe-lg-4">Discover Frequently Asked Questions?</h2>
                <a href="#contact" class="btn btn-primary px-4 py-2">WORK TOGETHER</a>
            </div>
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    @{
                        var faqQuestions = new[] {
                            "01. Curious about how to build your own UX strategy? Here are five simple steps.",
                            "02. Where Could a Career in UX Take You? Agency vs. In-House vs. Freelance?",
                            "03. What is a Problem Statement in UX? (And How To Write One?)",
                            "04. There are several techniques UX designers employ to arrive at a succinct?",
                            "05. What are the obstacles users are facing? What are they trying to do?"
                        };
                    }
                    @for(int i=0; i<faqQuestions.Length; i++)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading-@i">
                                <button class="accordion-button @(i != 0 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@i">
                                    @faqQuestions[i]
                                </button>
                            </h2>
                            <div id="collapse-@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet lacus enim. Proin euismod urna non urna condimentum, ac eleifend velit sollicitudin.
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
