                        <span asp-validation-for="Contact.Description" class="text-danger small"></span>
                    </div>
                    <div class="col-12 text-center" data-aos="fade-up" data-aos-delay="500">
                        <button type="submit" class="btn btn-primary px-5 py-3 btn-premium-contact">SEND MESSAGE</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="text-center mt-5" data-aos="fade-up">
            <div class="contact-icon-wrap icon-social d-inline-flex mx-2"><i class="fa-brands fa-facebook-f"></i></div>
            <div class="contact-icon-wrap icon-social d-inline-flex mx-2"><i class="fa-brands fa-twitter"></i></div>
            <div class="contact-icon-wrap icon-social d-inline-flex mx-2"><i class="fa-brands fa-instagram"></i></div>
            <div class="contact-icon-wrap icon-social d-inline-flex mx-2"><i class="fa-brands fa-linkedin-in"></i></div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="py-5 mb-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-4">
                <h2 class="fw-bold fs-1 mb-4 pe-lg-4" id="faqTitle">Discover Frequently Asked Questions?</h2>
                <a href="#contact" class="btn btn-primary px-4 py-2">WORK TOGETHER</a>
            </div>
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    @{
                        var faqQuestions = new[] {
                            "01. Curious about how to build your own UX strategy? Here are five simple steps.",
                            "02. Where Could a Career in UX Take You? Agency vs. In-House vs. Freelance?",
                            "03. What is a Problem Statement in UX? (And How To Write One?)",
                            "04. There are several techniques UX designers employ to arrive at a succinct?",
                            "05. What are the obstacles users are facing? What are they trying to do?"
                        };
                    }
                    @for(int i=0; i<faqQuestions.Length; i++)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading-@i">
                                <button class="accordion-button @(i != 0 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@i">
                                    @faqQuestions[i]
                                </button>
                            </h2>
                            <div id="collapse-@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet lacus enim. Proin euismod urna non urna condimentum, ac eleifend velit sollicitudin.
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section id="testimonials" class="py-5 bg-light sweep-section" style="position: relative; overflow: hidden;">
    <canvas id="testimonialsSweepCanvas" class="section-sweep-canvas"></canvas>
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block" data-aos="fade-down" id="testimonialsSubtitle"><i class="fa-solid fa-minus me-2"></i>Testimonials<i class="fa-solid fa-minus ms-2"></i></span>
            <h2 class="fw-bold fs-1 mb-3" data-aos="fade-up" id="testimonialsTitle">What Our Clients Say</h2>
            <p class="text-secondary mx-auto" style="max-width: 600px;" data-aos="fade-up" data-aos-delay="100" id="testimonialsDesc">
                Our clients' success is our best introduction. Discover how we have helped other brands scale and transform their digital businesses.
            </p>
        </div>

        <div class="row g-4">
            @{
                var testimonials = new[] {
                    new { 
                        Name = "Laura Gómez", 
                        Role = "Marketing Director, TechCorp", 
                        Content = "Working with Holix completely transformed our online presence. The UX/UI design is top-notch and we managed to increase our conversions by 45% in just two months. Highly recommended!",
                        Image = "https://ui-avatars.com/api/?name=Laura+Gomez&background=0D8ABC&color=fff&size=100"
                    },
                    new { 
                        Name = "Carlos Martínez", 
                        Role = "CEO, InnovaSolutions", 
                        Content = "The technical architecture they developed for our mobile application exceeded all our expectations. They are a highly professional team that understands both business and technology.",
                        Image = "https://ui-avatars.com/api/?name=Carlos+Martinez&background=10B981&color=fff&size=100"
                    },
                    new { 
                        Name = "Sofía Ruiz", 
                        Role = "Founder, EcoStore", 
                        Content = "From day 1, the Holix team demonstrated an exceptional level of commitment. Their digital marketing strategy quickly positioned us in the market and our ROI multiplied.",
                        Image = "https://ui-avatars.com/api/?name=Sofia+Ruiz&background=F59E0B&color=fff&size=100"
                    }
                };
            }
            @foreach(var (testimonial, index) in testimonials.Select((t, i) => (t, i)))
            {
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="@(index * 100)">
                    <div class="testimonial-card p-4 h-100 d-flex flex-column">
                        <div class="d-flex mb-3 text-warning fs-5">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <p class="text-secondary mb-4 flex-grow-1" style="font-style: italic;">"@testimonial.Content"</p>
                        <div class="d-flex align-items-center">
                            <img src="@testimonial.Image" alt="@testimonial.Name" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;">
                            <div>
                                <h6 class="fw-bold mb-0">@testimonial.Name</h6>
                                <small class="text-secondary">@testimonial.Role</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Portfolio Section -->
<section id="portfolio" class="py-5 my-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block" data-aos="fade-down">-Our Portfolio-</span>
            <h2 class="fw-bold fs-1 mb-3" id="portfolioHomeTitle" data-aos="fade-up">Featured Projects</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;" data-aos="fade-up" data-aos-delay="100">
                A selection of our latest and greatest work.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @if (Model != null && Model.Projects != null && Model.Projects.Any())
            {
                var delays = new[] { 0, 150, 300 };
                for (int i = 0; i < Model.Projects.Count(); i++)
                {
                    var project = Model.Projects.ElementAt(i);
                    var delay = i < delays.Length ? delays[i] : 300;
                    <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="@delay">
                        <div class="portfolio-card h-100">
                            @if (!string.IsNullOrEmpty(project.ImageUrl))
                            {
                                <div class="portfolio-card-image">
                                    <img src="@project.ImageUrl" alt="@project.Title">
                                    <div class="portfolio-card-overlay"></div>
                                </div>
                            }
                            <div class="portfolio-card-body">
                                <span class="portfolio-date text-secondary small">@project.CompletedAt.ToString("MMM yyyy")</span>
                                <h5 class="fw-bold mt-2 mb-1">
                                    <a asp-controller="Portfolio" asp-action="Details" asp-route-slug="@project.Slug" class="text-dark text-decoration-none">@project.Title</a>
                                </h5>
                                <span class="text-secondary small">@project.Client</span>
                                @if (!string.IsNullOrEmpty(project.Technologies))
                                {
                                    <div class="mt-2 d-flex flex-wrap gap-1">
                                        @foreach (var tech in project.Technologies.Split(','))
                                        {
                                            <span class="portfolio-tech-tag">@tech.Trim()</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-secondary">No projects yet. Check back soon!</p>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a asp-controller="Portfolio" asp-action="Index" class="btn btn-primary px-4 py-2 btn-premium">VIEW ALL PROJECTS</a>
        </div>
    </div>
</section>

<!-- Blog Section -->
<section id="blog" class="py-5 my-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block" data-aos="fade-down">-Our Blog-</span>
            <h2 class="fw-bold fs-1 mb-3" id="latestPostsTitle" data-aos="fade-up">Latest Posts</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;" data-aos="fade-up" data-aos-delay="100">
                Insights and updates from our team.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @if (Model != null && Model.BlogPosts != null && Model.BlogPosts.Any())
            {
                var delays = new[] { 0, 150, 300 };
                for (int i = 0; i < Model.BlogPosts.Count(); i++)
                {
                    var post = Model.BlogPosts.ElementAt(i);
                    var delay = i < delays.Length ? delays[i] : 300;
                    <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="@delay">
                        <div class="blog-card h-100">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="blog-card-image">
                                    <img src="@post.ImageUrl" alt="@post.Title">
                                </div>
                            }
                            <div class="blog-card-body">
                                <span class="blog-date text-secondary small">@post.PublishedAt.ToString("MMMM dd, yyyy")</span>
                                <h5 class="fw-bold mt-2 mb-2">
                                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="text-dark text-decoration-none">@post.Title</a>
                                </h5>
                                <p class="text-secondary small mb-3">@post.Excerpt</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-secondary">By @post.Author</span>
                                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="text-primary fw-bold small text-decoration-none">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-secondary">No blog posts yet. Check back soon!</p>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a asp-controller="Blog" asp-action="Index" class="btn btn-primary px-4 py-2 btn-premium">VIEW ALL POSTS</a>
        </div>
    </div>
</section>
