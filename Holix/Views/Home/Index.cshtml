    <canvas id="aboutSweepCanvas" class="section-sweep-canvas"></canvas>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 pe-lg-5" data-aos="fade-right">
