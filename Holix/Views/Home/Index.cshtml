<!-- Blog Section -->
<section id="blog" class="py-5 my-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block" data-aos="fade-down">-Our Blog-</span>
            <h2 class="fw-bold fs-1 mb-3" id="latestPostsTitle" data-aos="fade-up">Latest Posts</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;" data-aos="fade-up" data-aos-delay="100">
                Insights and updates from our team.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @if (Model != null && Model.BlogPosts != null && Model.BlogPosts.Any())
            {
                var delays = new[] { 0, 150, 300 };
                for (int i = 0; i < Model.BlogPosts.Count(); i++)
                {
                    var post = Model.BlogPosts.ElementAt(i);
                    var delay = i < delays.Length ? delays[i] : 300;
                    <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="@delay">
                        <div class="blog-card h-100">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="blog-card-image">
                                    <img src="@post.ImageUrl" alt="@post.Title">
                                </div>
                            }
                            <div class="blog-card-body">
                                <span class="blog-date text-secondary small">@post.PublishedAt.ToString("MMMM dd, yyyy")</span>
                                <h5 class="fw-bold mt-2 mb-2">
                                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="text-dark text-decoration-none">@post.Title</a>
                                </h5>
                                <p class="text-secondary small mb-3">@post.Excerpt</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-secondary">By @post.Author</span>
                                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="text-primary fw-bold small text-decoration-none">Read More <i class="fa-solid fa-arrow-right ms-1"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-secondary">No blog posts yet. Check back soon!</p>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a asp-controller="Blog" asp-action="Index" class="btn btn-primary px-4 py-2 btn-premium">VIEW ALL POSTS</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function() {
            const counters = document.querySelectorAll('.count-up');
            if (!counters.length) return;
            const observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        var el = entry.target;
                        var target = parseInt(el.getAttribute('data-target'), 10);
                        if (el.dataset.counted) return;
                        el.dataset.counted = 'true';
                        var current = 0;
                        var step = Math.ceil(target / 40);
                        var timer = setInterval(function() {
                            current += step;
                            if (current >= target) {
                                current = target;
                                clearInterval(timer);
                            }
                            el.textContent = current;
                        }, 30);
                        observer.unobserve(el);
                    }
                });
            }, { threshold: 0.5 });
            counters.forEach(function(c) { observer.observe(c); });
        })();

        /* ── Contact Sweep Canvas ── */
        (function() {
            var canvas = document.getElementById('contactSweepCanvas');
            if (!canvas) return;
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) { canvas.style.display = 'none'; return; }
            var ctx = canvas.getContext('2d');
            var w, h, lines = [];
            var MIN = 5, MAX = 8;
            function resize() {
                var rect = canvas.parentElement.getBoundingClientRect();
                w = canvas.width = rect.width;
                h = canvas.height = rect.height;
            }
            window.addEventListener('resize', resize);
            resize();
            function create() {
                var fromLeft = Math.random() < 0.5;
                var len = w * (0.45 + Math.random() * 0.45);
                return {
                    cx: fromLeft ? -len : w + len,
                    y: Math.random() * h,
                    len: len,
                    thick: 2 + Math.random() * 4,
                    dir: fromLeft ? 1 : -1,
                    speed: 1.5 + Math.random() * 2.5
                };
            }
            function update() {
                for (var i = lines.length - 1; i >= 0; i--) {
                    var l = lines[i];
                    l.cx += l.speed * l.dir;
                    if ((l.dir > 0 && l.cx - l.len / 2 > w) || (l.dir < 0 && l.cx + l.len / 2 < 0)) { lines.splice(i, 1); }
                }
                while (lines.length < MIN + Math.floor(Math.random() * (MAX - MIN + 1))) { lines.push(create()); }
            }
            function draw() {
                ctx.clearRect(0, 0, w, h);
                for (var i = 0; i < lines.length; i++) {
                    var l = lines[i];
                    var relPos = l.dir > 0 ? l.cx / w : (w - l.cx) / w;
                    var opacity = 0;
                    if (relPos < 0.25) opacity = Math.max(0, relPos / 0.25);
                    else if (relPos > 0.75) opacity = Math.max(0, (1 - relPos) / 0.25);
                    else opacity = 1;
                    ctx.globalAlpha = opacity * 0.25;
                    ctx.strokeStyle = 'rgb(46, 204, 113)';
                    ctx.lineWidth = l.thick;
                    ctx.beginPath();
                    ctx.moveTo(l.cx - l.len / 2, l.y);
                    ctx.lineTo(l.cx + l.len / 2, l.y);
                    ctx.stroke();
                }
                ctx.globalAlpha = 1;
            }
            function loop() { update(); draw(); requestAnimationFrame(loop); }
            loop();
        })();

        /* ── Contact Floating Shapes ── */
        (function() {
            var container = document.getElementById('contactShapes');
            if (!container) return;
            var shapes = ['circle', 'plus', 'diamond', 'hexagon'];
            var symbols = ['&lt;/&gt;', '+', '&#9670;', '&#9671;', '&#8226;', '&infin;'];
            for (var i = 0; i < 12; i++) {
                var el = document.createElement('div');
                el.className = 'tech-shape';
                var size = 8 + Math.random() * 16;
                el.style.cssText = 'width:' + size + 'px;height:' + size + 'px;left:' + (Math.random() * 90 + 5) + '%;top:' + (Math.random() * 90 + 5) + '%;' +
                    'animation-duration:' + (18 + Math.random() * 20) + 's;animation-delay:' + (Math.random() * -20) + 's;' +
                    'opacity:' + (0.04 + Math.random() * 0.06) + ';';
                if (Math.random() < 0.5) {
                    el.textContent = symbols[Math.floor(Math.random() * symbols.length)];
                    el.style.fontSize = size + 'px';
                    el.style.color = '#22c55e';
                } else {
                    el.style.border = '1.5px solid #22c55e';
                    el.style.borderRadius = Math.random() < 0.5 ? '50%' : '2px';
                    if (Math.random() < 0.3) el.style.transform = 'rotate(' + (Math.floor(Math.random() * 4) * 45) + 'deg)';
                }
                container.appendChild(el);
            }
        })();

        /* ── Contact Word Wrap ── */
        (function() {
            function wrapWords(root) {
                var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);
                var nodes = [];
                while (walker.nextNode()) nodes.push(walker.currentNode);
                nodes.forEach(function(node) {
                    var text = node.textContent;
                    var parts = text.split(/(\s+)/);
                    if (parts.length < 2) return;
                    var frag = document.createDocumentFragment();
                    for (var i = 0; i < parts.length; i++) {
                        if (parts[i].trim() === '') { frag.appendChild(document.createTextNode(parts[i])); }
                        else { var span = document.createElement('span'); span.className = 'hover-word'; span.textContent = parts[i]; frag.appendChild(span); }
                    }
                    node.parentNode.replaceChild(frag, node);
                });
            }
            var contact = document.getElementById('contact');
            if (!contact) return;
            var targets = contact.querySelectorAll('h1, h2, h3, h4, p, label, span, a, small, li');
            targets.forEach(function(el) {
                if (!el || el.closest('.hover-word') || el.classList.contains('contact-title') || el.querySelector('.hover-word')) return;
                wrapWords(el);
            });
        })();

        /* ── Contact Title Letter Cascade + Word Hover ── */
        (function() {
            var title = document.querySelector('.contact-title');
            if (!title) return;
            var text = title.textContent;
            title.textContent = '';
            var words = text.split(/(\s+)/);
            var allLetters = [];
            for (var w = 0; w < words.length; w++) {
                var word = words[w];
                if (word.trim() === '') {
                    var sp = document.createElement('span');
                    sp.className = 'letter-span';
                    sp.innerHTML = '&nbsp;';
                    title.appendChild(sp);
                    allLetters.push(sp);
                    continue;
                }
                var wordSpan = document.createElement('span');
                wordSpan.className = 'hover-word';
                for (var i = 0; i < word.length; i++) {
                    var letterSpan = document.createElement('span');
                    letterSpan.className = 'letter-span';
                    letterSpan.textContent = word[i];
                    wordSpan.appendChild(letterSpan);
                    allLetters.push(letterSpan);
                }
                title.appendChild(wordSpan);
            }
            var obs = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        allLetters.forEach(function(span, idx) { setTimeout(function() { span.classList.add('visible'); }, idx * 40); });
                        obs.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.3 });
            obs.observe(title);
        })();

        /* ── Contact Icon Clicks ── */
        (function() {
            function setupIcon(selector, activeClass) {
                var el = document.querySelector(selector);
                if (!el) return;
                el.addEventListener('click', function() {
                    this.classList.remove(activeClass);
                    void this.offsetWidth;
                    this.classList.add(activeClass);
                });
                el.addEventListener('animationend', function() { this.classList.remove(activeClass); });
            }
            setupIcon('.icon-location', 'icon-bounce-active');
            setupIcon('.icon-phone', 'icon-phone-active');
            setupIcon('.icon-email', 'icon-email-active');
            document.querySelectorAll('.icon-social').forEach(function(el) {
                el.addEventListener('click', function() {
                    this.classList.remove('icon-social-active');
                    void this.offsetWidth;
                    this.classList.add('icon-social-active');
                });
                el.addEventListener('animationend', function() { this.classList.remove('icon-social-active'); });
            });
        })();

        /* ── Contact Floating Labels ── */
        (function() {
            document.querySelectorAll('.floating-group .contact-input').forEach(function(input) {
                function update() { input.closest('.floating-group').classList.toggle('has-value', input.value.trim() !== ''); }
                input.addEventListener('input', update);
                input.addEventListener('focus', update);
                input.addEventListener('blur', update);
                update();
            });
        })();

        /* ── Blog Section Animations ── */
        (function() {
            var blog = document.getElementById('blog');
            if (!blog) return;

            /* Letter cascade on "Latest Posts" title */
            var title = document.getElementById('latestPostsTitle');
            if (title && !title.classList.contains('letter-cascaded')) {
                title.classList.add('letter-cascaded');
                var text = title.textContent;
                title.textContent = '';
                for (var i = 0; i < text.length; i++) {
                    var ch = text[i];
                    if (ch === ' ') {
                        var space = document.createElement('span');
                        space.className = 'letter-span';
                        space.innerHTML = '&nbsp;';
                        title.appendChild(space);
                    } else {
                        var span = document.createElement('span');
                        span.className = 'letter-span';
                        span.textContent = ch;
                        title.appendChild(span);
                    }
                }
                var letters = title.querySelectorAll('.letter-span');
                var obs = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            letters.forEach(function(span, idx) { setTimeout(function() { span.classList.add('visible'); }, idx * 35); });
                            obs.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.5 });
                obs.observe(title);
            }

            /* Word-by-word subtitle */
            var subtitle = blog.querySelector('p[data-aos="fade-up"][data-aos-delay="100"]');
            if (subtitle && !subtitle.classList.contains('word-cascaded')) {
                subtitle.classList.add('word-cascaded');
                var subText = subtitle.textContent;
                var subWords = subText.split(/\s+/);
                subtitle.textContent = '';
                subWords.forEach(function(word, idx) {
                    var span = document.createElement('span');
                    span.className = 'subtitle-word';
                    span.textContent = word;
                    span.style.transitionDelay = (idx * 50) + 'ms';
                    subtitle.appendChild(span);
                    if (idx < subWords.length - 1) subtitle.appendChild(document.createTextNode(' '));
                });
                var subObs = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            entry.target.querySelectorAll('.subtitle-word').forEach(function(w) { w.classList.add('visible'); });
                            subObs.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.5 });
                subObs.observe(subtitle);
            }

            /* Word-wrap all #blog text */
            (function() {
                function wrapWords(root) {
                    var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);
                    var nodes = [];
                    while (walker.nextNode()) nodes.push(walker.currentNode);
                    nodes.forEach(function(node) {
                        var text = node.textContent;
                        var parts = text.split(/(\s+)/);
                        if (parts.length < 2) return;
                        var frag = document.createDocumentFragment();
                        for (var i = 0; i < parts.length; i++) {
                            if (parts[i].trim() === '') { frag.appendChild(document.createTextNode(parts[i])); }
                            else { var span = document.createElement('span'); span.className = 'hover-word'; span.textContent = parts[i]; frag.appendChild(span); }
                        }
                        node.parentNode.replaceChild(frag, node);
                    });
                }
                var targets = blog.querySelectorAll('h1, h2, h3, h4, p, span, li, a, label, small, strong, em, blockquote, figcaption');
                targets.forEach(function(el) {
                    if (!el || el.closest('.hover-word') || el.classList.contains('letter-span') || el.classList.contains('subtitle-word') || el.querySelector('.hover-word') || el.querySelector('.letter-span') || el.querySelector('.subtitle-word')) return;
                    wrapWords(el);
                });
            })();
        })();
    </script>
}

