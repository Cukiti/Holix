<!-- Features Section (Why Choose Us) -->
<section id="features" class="py-5 my-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold mb-2 d-block">-Why Choose Us-</span>
            <h2 class="fw-bold fs-1 mb-3">Reasons to Choose Us</h2>
            <p class="text-secondary mx-auto" style="max-width: 500px;">
                Get the most of reduction in your team's operating costs for the whole product which creates amazing UI/UX experiences.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            @{
                var features = new[] {
                    new { Num = "01", Title = "Cutting-Edge Design", Desc = "Intuitive, beautiful interfaces that capture users from the first second." },
                    new { Num = "02", Title = "Ongoing Support", Desc = "24/7 technical assistance and maintenance so your system never stops running." },
                    new { Num = "03", Title = "Client Strategy", Desc = "Digital marketing plans focused on conversion and audience loyalty." },
                    new { Num = "04", Title = "Scalable Development", Desc = "Robust architecture that grows with your business without compromising performance." },
                    new { Num = "05", Title = "Advanced Technology", Desc = "We use the most modern frameworks to guarantee speed and security." },
                    new { Num = "06", Title = "Competitive Pricing", Desc = "Enterprise-level solutions at the best value, maximizing your budget." }
                };
            }
            @foreach(var item in features)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="reason-card h-100">
