@model IEnumerable<Holix.Models.BlogPost>

@{
    ViewData["Title"] = "Blog";
}

<style>
    /* Fix stretched-link containing block — prevents pseudo-element from covering the viewport */
    #blogGrid .blog-card { position: relative; }
    /* Blog header entrance underline */
    #blogHeaderUnderline {
        height: 3px;
        width: 0;
        background: var(--primary-color);
        margin: 0 auto;
        transition: opacity 0.3s ease;
    }
    #blogHeaderUnderline.visible { width: 100%; }
    #blogHeaderUnderline:hover { opacity: 1 !important; }
</style>

<canvas id="bgCanvas"></canvas>
<canvas id="blogBgCanvas"></canvas>

<section class="blog-page-section">
    <div class="container">
        <div class="text-center mb-5" id="blogHeader">
            <h1 class="fw-bold fs-1 mb-3" id="blogHeaderTitle">Our Blog</h1>
            <div id="blogHeaderUnderline"></div>
            <p class="text-secondary mx-auto" style="max-width: 600px;" id="blogHeaderSubtitle">
                Insights, stories, and updates from our team.
            </p>
        </div>

        @* Search Bar *@
        <div class="blog-search-wrap text-center mb-4">
            <div class="blog-search-group">
                <svg class="blog-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="blogSearchInput" class="blog-search-input" placeholder=" " autocomplete="off">
                <label for="blogSearchInput" class="blog-search-label">Search posts...</label>
                <button type="button" id="blogSearchClear" class="blog-search-clear" aria-label="Clear search">&times;</button>
            </div>
            <div id="blogSearchCounter" class="blog-search-counter">Showing @(Model != null ? Model.Count() : 0) of @(Model != null ? Model.Count() : 0) posts</div>
        </div>

        <div class="row g-4 blog-row" id="blogGrid">
            @if (Model != null && Model.Any())
            {
                foreach (var post in Model)
                {
                    <div class="col-md-6 col-lg-4 d-flex blog-card-wrap" data-title="@post.Title.ToLower()" data-excerpt="@post.Excerpt.ToLower()" data-author="@post.Author.ToLower()">
                        <div class="blog-card h-100 w-100">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="blog-card-image">
                                    <img src="@post.ImageUrl" alt="@post.Title">
                                </div>
                            }
                            else
                            {
                                <div class="blog-card-image blog-card-placeholder">
                                    <i class="fa-regular fa-newspaper"></i>
                                </div>
                            }
                            <div class="blog-card-body d-flex flex-column">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="blog-date text-secondary small">@post.PublishedAt.ToString("MMM dd, yyyy")</span>
                                    <span class="small text-secondary">&middot;</span>
                                    <span class="small text-secondary"><i class="fa-regular fa-user me-1"></i>@post.Author</span>
                                    <span class="small ms-auto blog-views">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        <span class="blog-views-count">@FormatViews(post.Views)</span>
                                    </span>
                                </div>
                                <h5 class="fw-bold mb-2">
                                    <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="text-dark text-decoration-none stretched-link">@post.Title</a>
                                </h5>
                                <p class="text-secondary small mb-3 flex-grow-1">@post.Excerpt</p>
                                <div class="mt-auto">
                                    <span class="text-primary fw-semibold small">
                                        Read More <i class="fa-solid fa-arrow-right ms-1"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-secondary">No blog posts published yet. Check back soon!</p>
                </div>
            }
        </div>

        <div id="blogNoResults" class="text-center py-5" style="display:none;">
            <p class="text-secondary fs-5">No posts found for your search</p>
        </div>
    </div>
</section>

@functions {
    string FormatViews(int views)
    {
        if (views >= 1000)
            return (views / 1000.0).ToString("0.#") + "k";
        return views.ToString();
    }
}

@section Scripts {
    <script>
        (function() {
            var canvas = document.getElementById('bgCanvas');
            if (!canvas) return;
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) { canvas.style.display = 'none'; return; }
            var ctx = canvas.getContext('2d');
            var w, h, shapes = [];
            var colors = ['rgba(46, 204, 113,', 'rgba(34, 197, 94,', 'rgba(16, 185, 129,', 'rgba(52, 211, 153,'];
            var types = ['circle', 'triangle', 'square', 'hexagon', 'diamond', 'plus'];
            function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize);
            resize();
            function create() {
                return {
                    type: types[Math.floor(Math.random() * types.length)],
                    x: Math.random() * (w + 200) - 100,
                    y: Math.random() * (h + 200) - 100,
                    size: 15 + Math.random() * 40,
                    rot: Math.random() * Math.PI * 2,
                    rotSpd: (Math.random() - 0.5) * 0.015,
                    vx: (Math.random() - 0.5) * 0.25,
                    vy: (Math.random() - 0.5) * 0.25 - 0.08,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    op: 0, life: 0, maxLife: 800 + Math.random() * 600
                };
            }
            function drawShape(s) {
                ctx.save();
                ctx.translate(s.x, s.y);
                ctx.rotate(s.rot);
                var a = s.op * 0.07;
                ctx.strokeStyle = s.color + a + ')';
                ctx.lineWidth = 1.5;
                ctx.fillStyle = s.color + (a * 0.4) + ')';
                ctx.beginPath();
                switch (s.type) {
                    case 'circle': ctx.arc(0, 0, s.size, 0, Math.PI * 2); break;
                    case 'triangle':
                        for (var i = 0; i < 3; i++) { var ang = (i / 3) * Math.PI * 2 - Math.PI / 2; var px = Math.cos(ang) * s.size, py = Math.sin(ang) * s.size; if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py); }
                        ctx.closePath(); break;
                    case 'square': ctx.rect(-s.size, -s.size, s.size * 2, s.size * 2); break;
                    case 'hexagon':
                        for (var i = 0; i < 6; i++) { var ang = (i / 6) * Math.PI * 2 - Math.PI / 6; var px = Math.cos(ang) * s.size, py = Math.sin(ang) * s.size; if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py); }
                        ctx.closePath(); break;
                    case 'diamond': ctx.moveTo(0, -s.size); ctx.lineTo(s.size, 0); ctx.lineTo(0, s.size); ctx.lineTo(-s.size, 0); ctx.closePath(); break;
                    case 'plus':
                        var t = s.size / 3; ctx.moveTo(-t, -s.size); ctx.lineTo(t, -s.size); ctx.lineTo(t, -t); ctx.lineTo(s.size, -t); ctx.lineTo(s.size, t); ctx.lineTo(t, t); ctx.lineTo(t, s.size); ctx.lineTo(-t, s.size); ctx.lineTo(-t, t); ctx.lineTo(-s.size, t); ctx.lineTo(-s.size, -t); ctx.lineTo(-t, -t);
                        ctx.closePath(); break;
                }
                ctx.fill(); ctx.stroke();
                ctx.restore();
            }
            function update() {
                for (var i = shapes.length - 1; i >= 0; i--) {
                    var s = shapes[i];
                    s.x += s.vx; s.y += s.vy; s.rot += s.rotSpd; s.life++;
                    if (s.life < 80) s.op = s.life / 80;
                    else if (s.life > s.maxLife - 80) s.op = (s.maxLife - s.life) / 80;
                    else s.op = 1;
                    if (s.life >= s.maxLife || s.x < -200 || s.x > w + 200 || s.y < -200 || s.y > h + 200) { shapes.splice(i, 1); }
                }
                if (shapes.length < 8 && Math.random() < 0.04) { shapes.push(create()); }
                if (shapes.length < 4) { shapes.push(create()); }
            }
            function draw() { ctx.clearRect(0, 0, w, h); for (var i = 0; i < shapes.length; i++) drawShape(shapes[i]); }
            function loop() { update(); draw(); requestAnimationFrame(loop); }
            loop();
        })();

        (function() {
            function wrapWords(root) {
                var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);
                var nodes = [];
                while (walker.nextNode()) nodes.push(walker.currentNode);
                nodes.forEach(function(node) {
                    var text = node.textContent;
                    var parts = text.split(/(\s+)/);
                    if (parts.length < 2) return;
                    var frag = document.createDocumentFragment();
                    for (var i = 0; i < parts.length; i++) {
                        if (parts[i].trim() === '') {
                            frag.appendChild(document.createTextNode(parts[i]));
                        } else {
                            var span = document.createElement('span');
                            span.className = 'hover-word';
                            span.textContent = parts[i];
                            frag.appendChild(span);
                        }
                    }
                    node.parentNode.replaceChild(frag, node);
                });
            }
            var targets = document.querySelectorAll('h1, h2, h3, h4, p, span, li, a, label, small, strong, em, blockquote, figcaption');
            targets.forEach(function(el) {
                if (!el || el.closest('.hover-word') || el.querySelector('.hover-word')) return;
                wrapWords(el);
            });
        })();

        /* ── Blog Search with Reordering Animation ── */
        (function() {
            var input = document.getElementById('blogSearchInput');
            var grid = document.getElementById('blogGrid');
            var clearBtn = document.getElementById('blogSearchClear');
            var noResults = document.getElementById('blogNoResults');
            var counter = document.getElementById('blogSearchCounter');
            if (!input || !grid) return;
            var cards = [].slice.call(grid.querySelectorAll('.blog-card-wrap'));
            var originalOrder = cards.slice();
            var filterTimeout = null;
            function updateCounter(count, total) {
                if (!counter) return;
                counter.classList.remove('blog-search-counter-update');
                void counter.offsetWidth;
                counter.textContent = 'Showing ' + count + ' of ' + total + ' posts';
                counter.classList.add('blog-search-counter-update');
            }
            function filter() {
                var q = input.value.trim().toLowerCase();
                if (q === '') {
                    cards.forEach(function(c) { c.classList.add('card-exit'); });
                    setTimeout(function() {
                        originalOrder.forEach(function(card) { grid.appendChild(card); });
                        cards.forEach(function(c, i) {
                            c.classList.remove('card-exit');
                            c.classList.remove('card-dimmed');
                            c.style.pointerEvents = '';
                            c.classList.add('card-enter');
                            c.style.animationDelay = (i * 60) + 'ms';
                        });
                        setTimeout(function() {
                            cards.forEach(function(c) {
                                c.classList.remove('card-enter');
                                c.style.animationDelay = '';
                            });
                        }, 60 * cards.length + 400);
                        if (noResults) noResults.style.display = 'none';
                        clearBtn.style.display = 'none';
                        updateCounter(cards.length, cards.length);
                    }, 150);
                    return;
                }
                cards.forEach(function(c) { c.classList.add('card-exit'); });
                setTimeout(function() {
                    var matches = [];
                    var nonMatches = [];
                    cards.forEach(function(card) {
                        var title = (card.getAttribute('data-title') || '').toLowerCase();
                        var excerpt = (card.getAttribute('data-excerpt') || '').toLowerCase();
                        var author = (card.getAttribute('data-author') || '').toLowerCase();
                        var match = title.indexOf(q) !== -1 || excerpt.indexOf(q) !== -1 || author.indexOf(q) !== -1;
                        if (match) matches.push(card);
                        else nonMatches.push(card);
                    });
                    matches.forEach(function(card) { grid.appendChild(card); });
                    nonMatches.forEach(function(card) { grid.appendChild(card); });
                    cards.forEach(function(c, i) {
                        c.classList.remove('card-exit');
                        var title = (c.getAttribute('data-title') || '').toLowerCase();
                        var excerpt = (c.getAttribute('data-excerpt') || '').toLowerCase();
                        var author = (c.getAttribute('data-author') || '').toLowerCase();
                        var match = title.indexOf(q) !== -1 || excerpt.indexOf(q) !== -1 || author.indexOf(q) !== -1;
                        if (match) {
                            c.classList.remove('card-dimmed');
                            c.style.pointerEvents = '';
                            c.classList.add('card-enter');
                            c.style.animationDelay = (i * 60) + 'ms';
                        } else {
                            c.classList.remove('card-enter');
                            c.classList.add('card-dimmed');
                            c.style.pointerEvents = 'none';
                        }
                    });
                    if (matches.length === 1) {
                        setTimeout(function() {
                            matches[0].classList.add('card-bounce');
                            setTimeout(function() { matches[0].classList.remove('card-bounce'); }, 500);
                        }, 60 * cards.length + 400);
                    }
                    setTimeout(function() {
                        cards.forEach(function(c) {
                            c.classList.remove('card-enter');
                            c.style.animationDelay = '';
                        });
                    }, 60 * cards.length + 400);
                    if (noResults) { noResults.style.display = matches.length === 0 ? 'block' : 'none'; }
                    clearBtn.style.display = 'flex';
                    updateCounter(matches.length, cards.length);
                }, 150);
            }
            input.addEventListener('input', function() {
                if (filterTimeout) clearTimeout(filterTimeout);
                filterTimeout = setTimeout(filter, 50);
            });
            if (clearBtn) {
                clearBtn.addEventListener('click', function() { input.value = ''; filter(); input.focus(); });
            }
            filter();
        })();

        /* ── Fix: prevent search bar clicks from being captured by any overlay ── */
        (function() {
            var searchInput = document.getElementById('blogSearchInput');
            var searchWrap = searchInput ? searchInput.closest('.blog-search-wrap') : null;
            if (searchWrap) {
                searchWrap.addEventListener('click', function(e) { e.stopPropagation(); });
                searchWrap.addEventListener('mousedown', function(e) { e.stopPropagation(); });
            }
        })();

        /* ── Blog Header Entrance Animations ── */
        (function() {
            var title = document.getElementById('blogHeaderTitle');
            var subtitle = document.getElementById('blogHeaderSubtitle');
            var underline = document.getElementById('blogHeaderUnderline');
            if (!title) return;

            /* Word-wrap header content for hover effect */
            (function() {
                function wrapWords(root) {
                    var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null, false);
                    var nodes = [];
                    while (walker.nextNode()) nodes.push(walker.currentNode);
                    nodes.forEach(function(node) {
                        var text = node.textContent;
                        var parts = text.split(/(\s+)/);
                        if (parts.length < 2) return;
                        var frag = document.createDocumentFragment();
                        for (var i = 0; i < parts.length; i++) {
                            if (parts[i].trim() === '') { frag.appendChild(document.createTextNode(parts[i])); }
                            else { var span = document.createElement('span'); span.className = 'hover-word'; span.textContent = parts[i]; frag.appendChild(span); }
                        }
                        node.parentNode.replaceChild(frag, node);
                    });
                }
                var header = document.getElementById('blogHeader');
                if (header) {
                    var hTargets = header.querySelectorAll('h1, h2, h3, h4, p, span, li, a, label, small, strong, em, blockquote, figcaption');
                    hTargets.forEach(function(el) {
                        if (!el || el.closest('.hover-word') || el.querySelector('.hover-word')) return;
                        wrapWords(el);
                    });
                }
            })();

            /* Re-fetch after word-wrap */
            var h1 = document.getElementById('blogHeaderTitle');
            if (!h1) return;
            var text = h1.textContent.replace(/\s+/g, ' ').trim();
            h1.textContent = '';
            var allLetters = [];
            for (var i = 0; i < text.length; i++) {
                var ch = text[i];
                if (ch === ' ') {
                    var sp = document.createElement('span');
                    sp.className = 'letter-span';
                    sp.innerHTML = '&nbsp;';
                    h1.appendChild(sp);
                    allLetters.push(sp);
                } else {
                    var span = document.createElement('span');
                    span.className = 'letter-span';
                    span.textContent = ch;
                    h1.appendChild(span);
                    allLetters.push(span);
                }
            }
            var totalTime = allLetters.length * 40;
            allLetters.forEach(function(span, idx) {
                setTimeout(function() { span.classList.add('visible'); }, idx * 40);
            });

            /* Subtitle word-by-word after title finishes */
            if (subtitle) {
                var subText = subtitle.textContent.replace(/\s+/g, ' ').trim();
                var subWords = subText.split(/\s+/);
                subtitle.textContent = '';
                subWords.forEach(function(word, idx) {
                    var span = document.createElement('span');
                    span.className = 'hover-word blog-header-sub-word';
                    span.textContent = word;
                    span.style.opacity = '0';
                    span.style.transform = 'translateY(10px)';
                    span.style.transition = 'opacity 0.4s cubic-bezier(0.23,1,0.32,1), transform 0.4s cubic-bezier(0.23,1,0.32,1)';
                    span.style.transitionDelay = (totalTime + 500 + idx * 50) + 'ms';
                    subtitle.appendChild(span);
                    if (idx < subWords.length - 1) subtitle.appendChild(document.createTextNode(' '));
                });
                setTimeout(function() {
                    subtitle.querySelectorAll('.blog-header-sub-word').forEach(function(w) {
                        w.style.opacity = '1';
                        w.style.transform = 'translateY(0)';
                    });
                }, 100);
            }

            /* Green underline after letters complete */
            if (underline) {
                setTimeout(function() {
                    underline.classList.add('visible');
                    underline.style.transition = 'width 0.8s cubic-bezier(0.23,1,0.32,1), opacity 0.3s ease';
                }, totalTime + 200);
            }
        })();

        /* ── Animated Background Canvas ── */
        (function() {
            var canvas = document.getElementById('blogBgCanvas');
            if (!canvas) return;
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) { canvas.style.display = 'none'; return; }
            var ctx = canvas.getContext('2d');
            var w, h, elems = [];
            var colors = ['rgba(46, 204, 113, 0.15)', 'rgba(34, 197, 94, 0.12)', 'rgba(16, 185, 129, 0.10)'];
            var types = ['line', 'circle', 'plus', 'dot'];
            function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize);
            resize();
            function create() {
                var type = types[Math.floor(Math.random() * types.length)];
                var color = colors[Math.floor(Math.random() * colors.length)];
                var elem = {
                    type: type,
                    x: Math.random() * w,
                    y: Math.random() * h,
                    color: color,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: (Math.random() - 0.5) * 0.3
                };
                if (type === 'line') {
                    elem.len = 40 + Math.random() * 80;
                    elem.thick = 1 + Math.random() * 1.5;
                } else if (type === 'circle') {
                    elem.r = 3 + Math.random() * 7;
                } else if (type === 'plus') {
                    elem.size = 6 + Math.random() * 4;
                    elem.thick = 1;
                } else if (type === 'dot') {
                    elem.r = 1.5 + Math.random() * 1;
                }
                return elem;
            }
            for (var i = 0; i < 30; i++) elems.push(create());
            function update() {
                for (var i = 0; i < elems.length; i++) {
                    var e = elems[i];
                    e.x += e.vx; e.y += e.vy;
                    if (e.x < 0 || e.x > w) e.vx *= -1;
                    if (e.y < 0 || e.y > h) e.vy *= -1;
                }
                while (elems.length < 20) elems.push(create());
            }
            function draw() {
                ctx.clearRect(0, 0, w, h);
                for (var i = 0; i < elems.length; i++) {
                    var e = elems[i];
                    ctx.strokeStyle = e.color;
                    ctx.fillStyle = e.color;
                    ctx.lineWidth = e.thick || 1;
                    if (e.type === 'line') {
                        ctx.beginPath();
                        ctx.moveTo(e.x - e.len / 2, e.y);
                        ctx.lineTo(e.x + e.len / 2, e.y);
                        ctx.stroke();
                    } else if (e.type === 'circle') {
                        ctx.beginPath();
                        ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
                        ctx.stroke();
                    } else if (e.type === 'plus') {
                        var s = e.size / 2;
                        ctx.beginPath();
                        ctx.moveTo(e.x - s, e.y); ctx.lineTo(e.x + s, e.y);
                        ctx.moveTo(e.x, e.y - s); ctx.lineTo(e.x, e.y + s);
                        ctx.stroke();
                    } else if (e.type === 'dot') {
                        ctx.beginPath();
                        ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
                        ctx.fill();
                    }
                }
            }
            function loop() { update(); draw(); requestAnimationFrame(loop); }
            loop();
        })();
    </script>
}

