<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Holix</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- SEO Meta Tags -->
    <meta name="description" content="Holix es una agencia digital enfocada en diseño UX/UI, marketing y desarrollo web y móvil. Orientados a la conversión y el ROI.">
    <meta name="keywords" content="Agencia digital, diseño UX/UI, desarrollo web, desarrollo de apps, marketing digital, ROI">
    <meta name="author" content="Holix Agency">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Holix.styles.css" asp-append-version="true" />

    <!-- Google Analytics (Dummy Integration for ROI Tracking - RN-005) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-dark fs-3" style="letter-spacing: -1px;" asp-area="" asp-controller="Home" asp-action="Index">Holix</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-center">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="home">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="about">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="features">Features</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="testimonials">Testimonials</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="blog">Blog</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact Us</a></li>
                    </ul>
                </div>
                <div class="d-none d-lg-block">
                    <a asp-controller="Home" asp-action="Index" asp-fragment="contact" class="btn btn-outline-primary rounded-pill px-4" style="border-width: 2px;">LETS TALK</a>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown d-inline-block ms-2">
                            <a class="btn btn-link text-dark dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">CMS</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index">Projects</a></li>
                                <li><a class="dropdown-item" asp-controller="Services" asp-action="Index">Services</a></li>
                                <li><a class="dropdown-item" asp-controller="Blog" asp-action="AdminList">Blog</a></li>
                                <li><a class="dropdown-item" asp-controller="Contact" asp-action="Index">Messages</a></li>
                                <li><a class="dropdown-item" asp-controller="Faqs" asp-action="Index">FAQs</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">Logout</a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-link text-dark ms-2 text-decoration-none fw-bold">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row g-4 mb-4 mt-3">
                <div class="col-lg-3"></div>
                <div class="col-lg-3">
                    <ul class="list-unstyled">
                        <li class="mb-4"><a href="#" class="footer-link">Web Solution</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Digital Marketing</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">App Design</a></li>
                        <li><a href="#" class="footer-link">App Development</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <ul class="list-unstyled">
                        <li class="mb-4"><a href="#" class="footer-link">Our Portfolio</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Our Blog</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Latest News</a></li>
                        <li><a href="#" class="footer-link">Contact Us</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <div class="mb-4 d-flex align-items-center">
                        <i class="fa-solid fa-envelope me-2 footer-icon"></i>
                        <span class="footer-text">info@hoolix.com</span>
                    </div>
                    <div class="social-links mt-4 pt-3">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
            
            <hr class="border-secondary mt-5 mb-4">
            
            <div class="d-flex justify-content-between align-items-center small">
                <span class="footer-text">&copy; 2022 Hoolix | All Rights Reserved by <a href="#" class="footer-link text-decoration-none">codewithandee</a></span>
                <div>
                    <a href="#" class="footer-link me-4 text-decoration-none">Privacy Policy</a>
                    <a href="#" class="footer-link text-decoration-none">Terms of Use</a>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 800, once: true });</script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
