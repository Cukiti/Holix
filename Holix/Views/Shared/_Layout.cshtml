<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Holix</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Holix.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top py-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Hoolix</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-center">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                        <li class="nav-item"><a class="nav-link" href="#blog">Blog</a></li>
                        <li class="nav-item"><a class="nav-link" href="#contact">Contact Us</a></li>
                    </ul>
                </div>
                <div class="d-none d-lg-block">
                    <a href="#contact" class="btn btn-outline-primary rounded-pill px-4" style="border-width: 2px;">LETS TALK</a>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown d-inline-block ms-2">
                            <a class="btn btn-link text-dark dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">CMS</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index">Projects</a></li>
                                <li><a class="dropdown-item" asp-controller="Services" asp-action="Index">Services</a></li>
                                <li><a class="dropdown-item" asp-controller="Faqs" asp-action="Index">FAQs</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                        <button type="submit" class="dropdown-item text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <h3 class="text-white fw-bold mb-3">Hoolix</h3>
                    <p class="small mb-4">Lorem ipsum dolor sit amet consecta tur adipiscing elit, sed do eiusmod tempor incididunt ut labore.</p>
                    <div class="newsletter-form d-flex">
                        <input type="email" class="form-control me-2" placeholder="Enter your email">
                        <button type="button"><i class="fa-solid fa-paper-plane"></i></button>
                    </div>
                </div>
                <div class="col-lg-2 offset-lg-1">
                    <h5 class="fw-bold fs-6">Our Services</h5>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Strategy & Research</a></li>
                        <li class="mb-2"><a href="#">Web Development</a></li>
                        <li class="mb-2"><a href="#">Web Solution</a></li>
                        <li class="mb-2"><a href="#">Digital Marketing</a></li>
                        <li class="mb-2"><a href="#">App Design</a></li>
                        <li><a href="#">App Development</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h5 class="fw-bold fs-6">Company</h5>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">About Company</a></li>
                        <li class="mb-2"><a href="#">Our Services</a></li>
                        <li class="mb-2"><a href="#">Our Portfolio</a></li>
                        <li class="mb-2"><a href="#">Our Blog</a></li>
                        <li class="mb-2"><a href="#">Latest News</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h5 class="fw-bold fs-6">Contact Us</h5>
                    <ul class="list-unstyled small">
                        <li class="mb-3 d-flex align-items-start">
                            <i class="fa-solid fa-location-dot mt-1 me-2 text-primary"></i>
                            <span>4517 Washington Ave. Manchester, Kentucky 39495</span>
                        </li>
                        <li class="mb-3">
                            <i class="fa-solid fa-phone me-2 text-primary"></i>
                            <span>+7894631546876</span>
                        </li>
                        <li class="mb-3">
                            <i class="fa-solid fa-envelope me-2 text-primary"></i>
                            <span>info@hoolix.com</span>
                        </li>
                    </ul>
                    <div class="social-links mt-4">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="d-flex justify-content-between align-items-center small mt-3">
                <span>&copy; 2022 Hoolix | All Rights Reserved by <span class="text-primary">codewithandee</span></span>
                <div>
                    <a href="#" class="me-3">Privacy Policy</a>
                    <a href="#">Terms of Use</a>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
