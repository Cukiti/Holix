<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Holix</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- SEO Meta Tags -->
    <meta name="description" content="Holix es una agencia digital enfocada en diseño UX/UI, marketing y desarrollo web y móvil. Orientados a la conversión y el ROI.">
    <meta name="keywords" content="Agencia digital, diseño UX/UI, desarrollo web, desarrollo de apps, marketing digital, ROI">
    <meta name="author" content="Holix Agency">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Holix.styles.css" asp-append-version="true" />

    <!-- Google Analytics (Dummy Integration for ROI Tracking - RN-005) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-dark fs-3" style="letter-spacing: -1px;" asp-area="" asp-controller="Home" asp-action="Index" id="navbarLogo"><span class="logo-letter">H</span><span class="logo-letter logo-o">o</span><span class="logo-letter">l</span><span class="logo-letter">i</span><span class="logo-letter">x</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-center">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="home">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="about">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="features">Features</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="testimonials">Testimonials</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#portfolio">Portfolio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="blog">Blog</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact Us</a></li>
                    </ul>
                </div>
                <div class="d-none d-lg-block">
                    <a asp-controller="Home" asp-action="Index" asp-fragment="contact" class="btn btn-outline-primary rounded-pill px-4 btn-glow-pulse lets-talk-glow" style="border-width: 2px;">LETS TALK</a>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown d-inline-block ms-2">
                            <a class="btn btn-link text-dark dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">CMS</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Projects" asp-action="Index">Projects</a></li>
                                <li><a class="dropdown-item" asp-controller="Services" asp-action="Index">Services</a></li>
                                <li><a class="dropdown-item" asp-controller="Blog" asp-action="AdminList">Blog</a></li>
                                <li><a class="dropdown-item" asp-controller="Contact" asp-action="Index">Messages</a></li>
                                <li><a class="dropdown-item" asp-controller="Faqs" asp-action="Index">FAQs</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">Logout</a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-link text-dark ms-2 text-decoration-none fw-bold nav-link-login">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row g-4 mb-4 mt-3">
                <div class="col-lg-3"></div>
                <div class="col-lg-3">
                    <ul class="list-unstyled">
                        <li class="mb-4"><a href="#" class="footer-link">Web Solution</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Digital Marketing</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">App Design</a></li>
                        <li><a href="#" class="footer-link">App Development</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <ul class="list-unstyled">
                        <li class="mb-4"><a href="#" class="footer-link">Our Portfolio</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Our Blog</a></li>
                        <li class="mb-4"><a href="#" class="footer-link">Latest News</a></li>
                        <li><a href="#" class="footer-link">Contact Us</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <div class="mb-4 d-flex align-items-center">
                        <i class="fa-solid fa-envelope me-2 footer-icon"></i>
                        <span class="footer-text">info@hoolix.com</span>
                    </div>
                    <div class="social-links mt-4 pt-3">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
            
            <hr class="border-secondary mt-5 mb-4">
            
            <div class="d-flex justify-content-between align-items-center small">
                <span class="footer-text">&copy; 2022 Hoolix | All Rights Reserved by <a href="#" class="footer-link text-decoration-none">codewithandee</a></span>
                <div>
                    <a href="#" class="footer-link me-4 text-decoration-none">Privacy Policy</a>
                    <a href="#" class="footer-link text-decoration-none">Terms of Use</a>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 800, once: true });</script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function() {
            var nav = document.querySelector('.navbar');
            if (nav) {
                function onScroll() {
                    if (window.scrollY > 20) nav.classList.add('navbar-scrolled');
                    else nav.classList.remove('navbar-scrolled');
                }
                window.addEventListener('scroll', onScroll, { passive: true });
                onScroll();
            }
        })();

        (function() {
            var navLinks = document.querySelectorAll('.navbar-nav .nav-link');

            function setActive(link) {
                navLinks.forEach(function(l) { l.classList.remove('active-link'); });
                if (link) link.classList.add('active-link');
            }

            /* — Initial active from URL (fallback for separate pages) — */
            (function init() {
                var path = window.location.pathname.toLowerCase().replace(/\/+$/, '') || '/';
                var hash = window.location.hash.replace('#', '');
                var matched = null;
                navLinks.forEach(function(link) {
                    var href = link.getAttribute('href');
                    if (!href) return;
                    var hrefPath = href.split('#')[0].toLowerCase().replace(/\/+$/, '') || '/';
                    var hrefHash = href.split('#')[1];
                    if (hrefPath === path && (!hrefHash || hrefHash === hash)) {
                        matched = link;
                    }
                });
                if (matched) setActive(matched);
            })();

            /* — Instant click feedback — */
            navLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    setActive(link);
                });
            });
        })();

        (function() {
            var logoLetters = document.querySelectorAll('.logo-letter');
            if (!logoLetters.length) return;
            var logo = document.getElementById('navbarLogo');
            if (!logo) return;
            logo.addEventListener('mouseenter', function() {
                logoLetters.forEach(function(letter, idx) {
                    setTimeout(function() {
                        letter.classList.add('logo-letter-hover');
                    }, idx * 50);
                });
            });
            logo.addEventListener('mouseleave', function() {
                logoLetters.forEach(function(letter) {
                    letter.classList.remove('logo-letter-hover');
                });
            });
        })();

        (function() {
            var navLinks = document.querySelectorAll('.navbar-nav .nav-link');
            if (!navLinks.length) return;
            var ray = document.createElement('div');
            ray.id = 'navRay';
            document.body.appendChild(ray);
            navLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    var rect = this.getBoundingClientRect();
                    var cx = rect.left + rect.width / 2;
                    var cy = rect.top + rect.height / 2;
                    ray.style.left = cx + 'px';
                    ray.style.top = cy + 'px';
                    ray.classList.remove('nav-ray-active');
                    void ray.offsetWidth;
                    ray.classList.add('nav-ray-active');
                });
            });
            ray.addEventListener('animationend', function() { this.classList.remove('nav-ray-active'); });
        })();

        (function() {
            var navLinks = document.querySelectorAll('.navbar-nav .nav-link');
            if (!navLinks.length) return;
            navLinks.forEach(function(link) {
                var text = link.textContent;
                link.textContent = '';
                for (var i = 0; i < text.length; i++) {
                    var ch = text[i];
                    if (ch === ' ') {
                        var space = document.createElement('span');
                        space.className = 'nav-letter';
                        space.innerHTML = '&nbsp;';
                        link.appendChild(space);
                    } else {
                        var span = document.createElement('span');
                        span.className = 'nav-letter';
                        span.textContent = ch;
                        link.appendChild(span);
                    }
                }
                link.addEventListener('mouseenter', function() {
                    var letters = this.querySelectorAll('.nav-letter');
                    letters.forEach(function(l, idx) {
                        l.style.transitionDelay = (idx * 30) + 'ms';
                        l.classList.add('nav-letter-hover');
                    });
                });
                link.addEventListener('mouseleave', function() {
                    var letters = this.querySelectorAll('.nav-letter');
                    letters.forEach(function(l) {
                        l.classList.remove('nav-letter-hover');
                        l.style.transitionDelay = '0ms';
                    });
                });
            });
        })();

        /* ── Global Breathing Text Animation ── */
        (function() {
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            if (document.querySelector('.breath-large')) return;

            function skip(el) {
                return !el || el.closest('.navbar, footer, .particle-canvas');
            }

            function hasBreath(el) {
                return el.matches('.breath-large, .breath-medium, .breath-small, .breath-icon, .breath-card, .breath-button, .hero-float-label, .hero-float-title, .hero-float-desc, .hero-shape, .lets-talk-glow');
            }

            /* Text elements */
            var textTags = document.querySelectorAll('h1, h2, h3, h4, h5, p, span, li, a, label, small, strong, em, blockquote, figcaption');
            textTags.forEach(function(el) {
                if (skip(el) || hasBreath(el)) return;
                if (!el.textContent.trim()) return;
                var tag = el.tagName.toLowerCase();
                var cls;
                if (tag === 'h1' || tag === 'h2') cls = 'breath-large';
                else if (tag === 'h3' || tag === 'h4' || tag === 'h5') cls = 'breath-medium';
                else cls = 'breath-small';
                el.classList.add(cls);
                el.style.animationDelay = (Math.random() * 2) + 's';
            });

            /* Icons & small UI */
            var icons = document.querySelectorAll('.service-icon-container, i.fa-solid, i.fa-regular, i.fa-brands, .form-label');
            icons.forEach(function(el) {
                if (skip(el) || hasBreath(el)) return;
                el.classList.add('breath-icon');
                el.style.animationDelay = (Math.random() * 2) + 's';
            });

            /* Cards */
            var cards = document.querySelectorAll('.card');
            cards.forEach(function(el) {
                if (skip(el) || hasBreath(el)) return;
                el.classList.add('breath-card');
                el.style.animationDelay = (Math.random() * 2) + 's';
            });

            /* Buttons (except LET'S TALK) */
            var btns = document.querySelectorAll('button, a.btn');
            btns.forEach(function(el) {
                if (skip(el) || hasBreath(el)) return;
                el.classList.add('breath-button');
                el.style.animationDelay = (Math.random() * 2) + 's';
            });

            /* Input fields */
            var inputs = document.querySelectorAll('input, textarea, select');
            inputs.forEach(function(el) {
                if (skip(el) || hasBreath(el)) return;
                el.classList.add('breath-small');
                el.style.animationDelay = (Math.random() * 2) + 's';
            });
        })();

        /* ── Floating Green Particles ── */
        (function() {
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            var sections = ['home', 'about', 'features', 'testimonials', 'contact'];
            sections.forEach(function(id) {
                var sec = document.getElementById(id);
                if (!sec || sec.querySelector('.particle-canvas')) return;
                if (sec.style.position !== 'relative') sec.style.position = 'relative';
                if (sec.style.overflow !== 'hidden') sec.style.overflow = 'hidden';
                var container = document.createElement('div');
                container.className = 'particle-canvas';
                sec.insertBefore(container, sec.firstChild);
                var count = 6 + Math.floor(Math.random() * 4);
                var shapes = ['circle', 'circle', 'circle', 'line', 'plus'];
                for (var i = 0; i < count; i++) {
                    var dot = document.createElement('div');
                    dot.className = 'particle-dot';
                    var shape = shapes[i % shapes.length];
                    var size = 4 + Math.random() * 8;
                    dot.style.left = (5 + Math.random() * 90) + '%';
                    dot.style.top = (5 + Math.random() * 90) + '%';
                    dot.style.animationDelay = -(Math.random() * 6) + 's';
                    dot.style.animationDuration = (5 + Math.random() * 4) + 's';
                    if (shape === 'circle') {
                        dot.style.width = size + 'px';
                        dot.style.height = size + 'px';
                        dot.style.borderRadius = '50%';
                        dot.style.background = 'rgba(34,197,94,0.15)';
                    } else if (shape === 'line') {
                        dot.style.width = (size * 2) + 'px';
                        dot.style.height = '2px';
                        dot.style.borderRadius = '2px';
                        dot.style.background = 'rgba(34,197,94,0.15)';
                        dot.style.transform = 'rotate(' + (Math.random() * 180) + 'deg)';
                    } else if (shape === 'plus') {
                        dot.innerHTML = '+';
                        dot.style.fontSize = (size + 4) + 'px';
                        dot.style.color = 'rgba(34,197,94,0.12)';
                        dot.style.fontWeight = '300';
                        dot.style.background = 'none';
                        dot.style.width = 'auto';
                        dot.style.height = 'auto';
                    }
                    container.appendChild(dot);
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
