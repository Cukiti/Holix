{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch (http)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}\\Holix\\bin\\Debug\\net10.0\\Holix.exe",
            "cwd": "${workspaceFolder}\\Holix",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5199",
                "DOTNET_ROOT": "${env:USERPROFILE}\\.dotnet",
                "DOTNET_MULTILEVEL_LOOKUP": "0",
                "PATH": "${env:USERPROFILE}\\.dotnet;${env:PATH}"
            }
        },
        {
            "name": "Launch (https)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}\\Holix\\bin\\Debug\\net10.0\\Holix.exe",
            "cwd": "${workspaceFolder}\\Holix",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7297;http://localhost:5199",
                "DOTNET_ROOT": "${env:USERPROFILE}\\.dotnet",
                "DOTNET_MULTILEVEL_LOOKUP": "0",
                "PATH": "${env:USERPROFILE}\\.dotnet;${env:PATH}"
            }
        }
    ]
}
